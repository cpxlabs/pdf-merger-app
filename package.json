{
  "name": "pdf-merger-app",
  "private": true,
  "version": "0.1.0",
  "description": "Desktop PDF merger with file browsing and drag-free ordering controls.",
  "main": "electron/main.js",
  "scripts": {
    "dev": "concurrently -k \"vite\" \"wait-on tcp:5173 && cross-env ELECTRON_RENDERER_URL=http://127.0.0.1:5173 electron .\"",
    "start": "pnpm dev",
    "build": "vite build",
    "test": "vitest run",
    "test:watch": "vitest",
    "desktop": "electron .",
    "preview:desktop": "vite build && electron ."
  },
  "dependencies": {
    "pdf-lib": "^1.17.1",
    "react": "^19.1.1",
    "react-dom": "^19.1.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^5.1.0",
    "@testing-library/jest-dom": "^6.8.0",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "concurrently": "^9.2.1",
    "cross-env": "^10.0.0",
    "electron": "^40.0.0",
    "jsdom": "^26.1.0",
    "vite": "^7.1.7",
    "vitest": "^3.2.4",
    "wait-on": "^8.0.5"
  }
}
